# ─────────────────────────────────────────────────────────────
# Bolna × Loom — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# ── LLM provider keys (used by Loom) ─────────────────────────
# Set at least one. Loom reads these by their standard vendor names.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Loom routing defaults ────────────────────────────────────
# Used when the routing layer has no strong preference.
LOOM_DEFAULT_PROVIDER=openai
LOOM_DEFAULT_MODEL=gpt-4o-mini

# ── Bolna (voice layer) ──────────────────────────────────────
BOLNA_API_KEY=
# Identifier of the Bolna agent that calls our webhook.
BOLNA_AGENT_ID=

# ── Backend / app ────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
